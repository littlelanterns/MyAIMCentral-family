# MyAIM Central — Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git

# ============================================================
# STEWARDSHIP DATABASE (for audit + extraction queries)
# ============================================================
# Get from: StewardShip Supabase project → Settings → API
STEWARDSHIP_SUPABASE_URL=https://dkcyaklyqxhkhcnpdtwf.supabase.co
STEWARDSHIP_SUPABASE_ANON_KEY=YOUR_STEWARDSHIP_ANON_KEY_HERE

# Get from: StewardShip Supabase → Settings → Database → Connection string (URI)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
STEWARDSHIP_DATABASE_URL=YOUR_STEWARDSHIP_DATABASE_URL_HERE

# ============================================================
# MYAIM v2 SUPABASE (create new project for the build)
# ============================================================
# Create at: https://supabase.com/dashboard → New Project
NEXT_PUBLIC_SUPABASE_URL=YOUR_V2_SUPABASE_URL_HERE
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_V2_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_V2_SERVICE_ROLE_KEY_HERE
DATABASE_URL=YOUR_V2_DATABASE_URL_HERE

# ============================================================
# AI SERVICES
# ============================================================
# OpenAI — for text-embedding-3-small (embedding pipeline)
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE

# OpenRouter — for multi-model routing (Claude, Haiku, Sonnet)
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE

# Anthropic — if calling Claude API directly
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# ============================================================
# STRIPE (test mode keys — PRD-31)
# ============================================================
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# ============================================================
# APP CONFIG
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
