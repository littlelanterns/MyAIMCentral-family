# MyAIM Central — Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git

# ============================================================
# STEWARDSHIP DATABASE (for audit + extraction queries)
# ============================================================
# Get from: StewardShip Supabase project → Settings → API
STEWARDSHIP_SUPABASE_URL=https://dkcyaklyqxhkhcnpdtwf.supabase.co
STEWARDSHIP_SUPABASE_ANON_KEY=YOUR_STEWARDSHIP_ANON_KEY_HERE

# Get from: StewardShip Supabase → Settings → Database → Connection string (URI)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
STEWARDSHIP_DATABASE_URL=YOUR_STEWARDSHIP_DATABASE_URL_HERE

# ============================================================
# MYAIM v2 SUPABASE (create new project for the build)
# ============================================================
# Create at: https://supabase.com/dashboard → New Project
VITE_SUPABASE_URL=YOUR_V2_SUPABASE_URL_HERE
VITE_SUPABASE_ANON_KEY=YOUR_V2_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_V2_SERVICE_ROLE_KEY_HERE
DATABASE_URL=YOUR_V2_DATABASE_URL_HERE

# ============================================================
# AI SERVICES
# ============================================================
# OpenAI — for text-embedding-3-small (embedding pipeline)
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE

# OpenRouter — for multi-model routing (Claude, Haiku, Sonnet)
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE

# Anthropic — if calling Claude API directly
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# ============================================================
# STRIPE (test mode keys — PRD-31)
# ============================================================
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# ============================================================
# APP CONFIG
# ============================================================
VITE_APP_URL=http://localhost:5173
NODE_ENV=development

# ============================================================
# E2E TEST CREDENTIALS (never commit real values)
# ============================================================
E2E_MOM_EMAIL=mom@example.com
E2E_MOM_PASSWORD=YOUR_PASSWORD_HERE
E2E_FAMILY_LOGIN_NAME=YourFamilyLoginName

# Family password (Family-Auth-Two-Door) — the shared password for family
# login. Edit the value, then run `npm run family:password` to apply it to
# Supabase (signs in as E2E_MOM_EMAIL and calls the set_family_password RPC;
# hashing and strength validation happen server-side).
E2E_FAMILY_PASSWORD=YOUR_FAMILY_PASSWORD_HERE

# Testworth demo family password (seeded by migration 100252; E2E suite)
E2E_TESTWORTH_FAMILY_PASSWORD=Lanterns2026
