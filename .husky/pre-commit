#!/usr/bin/env sh
#
# Pre-commit hook — MyAIM Central
#
# Orchestration Checkpoint 3. Checks (in order):
#
# 1. Banned patterns: Convention #257 (UTC date bug), secret detection
#    — blocks unless OVERRIDE_REASON env var provides a reason
# 2. Mom-UI evidence advisory (warns, never blocks)
# 3. TypeScript build check (tsc -b) — hard block, matches Vercel
# 4. Schema:dump enforcement — hard block, Convention #244
#
# Override for banned patterns (items 1 only):
#   OVERRIDE_REASON="explanation" git commit -m "message"
#   Override is recorded to .claude/state/OVERRIDES.md.
#
# Override for TypeScript/schema (items 3-4):
#   git commit --no-verify
#
# Why tsc -b (not --noEmit)
# -------------------------
# Repo's tsconfig.json is project-references solution style. tsc -b
# matches what Vercel runs. Code that passes vite dev can fail deploy.
#
# Failure interpreter
# -------------------
# Every blocked check includes: what's wrong, why it matters (the
# consequence if shipped), recommended fix, and convention reference.

set -e

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# --- File category detection ---
TS_STAGED=false
MIGRATION_STAGED=false
SCHEMA_STAGED=false
UI_STAGED=false
for f in $STAGED_FILES; do
  case "$f" in
    *.ts|*.tsx) TS_STAGED=true ;;
    supabase/migrations/*.sql) MIGRATION_STAGED=true ;;
    claude/live_schema.md) SCHEMA_STAGED=true ;;
  esac
  case "$f" in
    src/components/*|src/pages/*|src/features/*|*.css) UI_STAGED=true ;;
  esac
done

# =========================================================================
# CHECK 1: Banned pattern detection (overrideable via OVERRIDE_REASON)
# =========================================================================
PATTERN_VIOLATIONS=false

for f in $STAGED_FILES; do
  case "$f" in
    *.ts|*.tsx)
      # Convention #257: UTC date bug — only ADDED lines in the diff
      if git diff --cached -U0 -- "$f" | grep '^+' | grep -v '^+++' | grep -qE '\.toISOString\(\)\.(split|slice|substring|substr)'; then
        PATTERN_VIOLATIONS=true
        echo ""
        echo "⚠️  BANNED PATTERN — Convention #257 violation"
        echo ""
        echo "  File: $f"
        echo "  Pattern: .toISOString().split/.slice/.substring/.substr"
        echo ""
        echo "  Why this matters: This pattern caused the systemic UTC date"
        echo "  bug that took 3 days to fix across 21 files (March 2026). It"
        echo "  silently produces wrong dates in non-UTC timezones — every"
        echo "  family member not in UTC sees tasks on the wrong day. The fix"
        echo "  touched 30+ files and required a server-side trigger to prevent"
        echo "  recurrence."
        echo ""
        echo "  Recommended fix: import { todayLocalIso } from '@/utils/dates'"
        echo "  Reference: CLAUDE.md Convention #257, eslint.config.js"
      fi
      ;;
  esac
done

# Secret detection: check ADDED lines for API keys/secrets in source files
for f in $STAGED_FILES; do
  case "$f" in
    *.env*|.claude/*|claude/*|supabase/config.toml|*.sample|*.md) continue ;;
  esac
  case "$f" in
    *.ts|*.tsx|*.js|*.json)
      if git diff --cached -U0 -- "$f" | grep '^+' | grep -v '^+++' | grep -qE 'eyJhbGciOiJ[A-Za-z0-9]|sb_secret_[a-zA-Z0-9]{10,}'; then
        PATTERN_VIOLATIONS=true
        echo ""
        echo "⚠️  BANNED PATTERN — Possible secret in source code"
        echo ""
        echo "  File: $f"
        echo ""
        echo "  Why this matters: Secrets committed to git persist in history"
        echo "  even after deletion and can be scraped by automated tools."
        echo "  Service role keys grant full database access bypassing all"
        echo "  RLS policies — a leaked key is a complete data breach."
        echo ""
        echo "  Recommended fix: Move to .env.local (gitignored) or Supabase Vault."
        echo "  Reference: OWASP A02:2021 Cryptographic Failures"
      fi
      ;;
  esac
done

if [ "$PATTERN_VIOLATIONS" = "true" ]; then
  if [ -n "$OVERRIDE_REASON" ]; then
    mkdir -p .claude/state
    {
      echo ""
      echo "## $(date '+%Y-%m-%d %H:%M') — Pre-commit override"
      echo "- **Reason:** $OVERRIDE_REASON"
      echo "- **Staged files with violations:** see commit diff"
    } >> .claude/state/OVERRIDES.md
    git add .claude/state/OVERRIDES.md 2>/dev/null || true
    echo ""
    echo "⚠️  Override recorded to .claude/state/OVERRIDES.md"
    echo "  The orchestrator will surface this at next session start."
  else
    echo ""
    echo "  To override: OVERRIDE_REASON=\"your reason\" git commit -m \"message\""
    echo ""
    exit 1
  fi
fi

# =========================================================================
# CHECK 2: Mom-UI evidence advisory (never blocks)
# =========================================================================
if [ "$UI_STAGED" = "true" ]; then
  ACTIVE_BUILD=""
  for candidate in .claude/rules/current-builds/*.md; do
    case "$candidate" in
      */IDLE.md) continue ;;
      *) [ -f "$candidate" ] && ACTIVE_BUILD="$candidate" && break ;;
    esac
  done
  if [ -n "$ACTIVE_BUILD" ]; then
    if ! grep -q "Mom-UI Verification" "$ACTIVE_BUILD" 2>/dev/null; then
      echo ""
      echo "ℹ️  UI files changed — no Mom-UI Verification section in active build."
      echo "  Build file: $ACTIVE_BUILD"
      echo ""
      echo "  Why this matters: Visual changes need eyes-on verification at"
      echo "  desktop (≥1024px), tablet (~768px), and mobile (≤640px). Without"
      echo "  recorded verification, visual breaks compound silently between"
      echo "  phases."
      echo ""
      echo "  Action: Add '## Mom-UI Verification' table to the active build file."
      echo "  (Advisory only — commit proceeds.)"
      echo ""
    fi
  fi
fi

# =========================================================================
# CHECK 3: TypeScript build (existing, hard block)
# =========================================================================
if [ "$TS_STAGED" = "true" ]; then
  echo "Running TypeScript project build check (tsc -b)..."
  if ! ./node_modules/.bin/tsc -b; then
    echo ""
    echo "TypeScript errors found. Fix them before committing."
    echo ""
    echo "  Why this matters: Vercel uses the same tsc -b mode with strict"
    echo "  checking (noUnusedLocals, noUnusedParameters). Code that works in"
    echo "  vite dev will fail on deploy."
    echo ""
    echo "  Override: git commit --no-verify (but Vercel will still reject it)"
    exit 1
  fi
else
  echo "No .ts/.tsx staged — skipping TypeScript check."
fi

# =========================================================================
# CHECK 4: Schema:dump enforcement (existing, hard block)
# =========================================================================
if [ "$MIGRATION_STAGED" = "true" ] && [ "$SCHEMA_STAGED" = "false" ]; then
  echo ""
  echo "[error] Migration file staged without live_schema.md update."
  echo ""
  echo "  Why this matters: Convention #244 requires live_schema.md to reflect"
  echo "  the current database state. Without it, the next build session works"
  echo "  from a stale schema reference and may write incorrect migrations."
  echo ""
  echo "  Fix: npm run schema:dump"
  echo "  Then: git add claude/live_schema.md"
  echo "  Then: retry the commit."
  echo ""
  echo "  Reference: CLAUDE.md Convention #244"
  echo ""
  echo "  Override: git commit --no-verify (creates schema drift)"
  echo ""
  exit 1
fi

exit 0
