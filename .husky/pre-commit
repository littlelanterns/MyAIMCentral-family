#!/usr/bin/env sh
#
# Pre-commit hook — MyAIM Central
#
# File-type-aware check managed by Husky v9 (installed via `prepare`
# lifecycle script in package.json; writes core.hooksPath = .husky/_).
#
# Behavior
# --------
# - .ts / .tsx staged → run `./node_modules/.bin/tsc -b` (strict build,
#   matches the mode Vercel uses — catches noUnusedLocals,
#   noUnusedParameters, and strict type issues that `vite dev`'s
#   esbuild silently tolerates). Blocks the commit on error.
# - Doc-only commits (.md / .json / .yml etc., no .ts/.tsx) → skip the
#   TS check entirely. Fast path for doc-only work.
# - supabase/migrations/*.sql staged → claude/live_schema.md MUST be
#   staged in the same commit (Convention #244 enforcement). Blocks
#   the commit if missing. Escape hatch: `git commit --no-verify`.
#
# Why tsc -b (not --noEmit)
# -------------------------
# Repo's tsconfig.json is a project-references solution style
# (`references: [...], files: []`) with composite sub-projects. That's
# exactly what tsc -b was designed for, and package.json's `build`
# script already uses `tsc -b && vite build`. Running the same mode
# here means this hook sees what Vercel sees.
#
# Previous state
# --------------
# Replaces the raw `.git/hooks/pre-commit` shell script that ran
# `npx tsc --noEmit`. That hook was NOT version-controlled, used the
# global npm cache (broke during the April 2026 npm/nvm4w corruption
# incident), and skipped type-check granularity. This replacement is
# committed to the repo and auto-installs via Husky on every
# `npm install`.
#
# Schema:dump enforcement (Phase 0.26 S6)
# ---------------------------------------
# Promotes the prior non-blocking migration warning to a hard block.
# File-presence check only — does not verify freshness (mtime or
# content diff). mtime does not travel reliably through git operations
# (clones, rebases, stash pops) and diff-based checks add fragility
# for marginal benefit. Catches the "forgot entirely" failure mode,
# which is the actual failure mode. The "willfully staged stale
# version" case is outside hook scope.

set -e

# Get staged files (added, copied, modified, renamed — exclude deletions)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Detect file categories
TS_STAGED=false
MIGRATION_STAGED=false
SCHEMA_STAGED=false
for f in $STAGED_FILES; do
  case "$f" in
    *.ts|*.tsx)
      TS_STAGED=true
      ;;
    supabase/migrations/*.sql)
      MIGRATION_STAGED=true
      ;;
    claude/live_schema.md)
      SCHEMA_STAGED=true
      ;;
  esac
done

# TypeScript check — only when .ts/.tsx staged
if [ "$TS_STAGED" = "true" ]; then
  echo "Running TypeScript project build check (tsc -b)..."
  if ! ./node_modules/.bin/tsc -b; then
    echo ""
    echo "TypeScript errors found. Fix them before committing."
    echo "Vercel uses the same tsc -b mode and will reject this build."
    exit 1
  fi
else
  echo "No .ts/.tsx staged — skipping TypeScript check."
fi

# Schema:dump enforcement — hard block when migration staged without
# a concurrent claude/live_schema.md update. File-presence check only
# (see header comment re: why freshness isn't verified).
if [ "$MIGRATION_STAGED" = "true" ] && [ "$SCHEMA_STAGED" = "false" ]; then
  echo ""
  echo "[error] Migration file staged without live_schema.md update."
  echo ""
  echo "Convention #244 requires schema regeneration after migration changes."
  echo "Run: npm run schema:dump"
  echo "Then: git add claude/live_schema.md"
  echo "Then: retry the commit."
  echo ""
  echo "This hook can be bypassed with --no-verify, but doing so creates schema"
  echo "drift between the repo and production. If you bypass, the next commit"
  echo "MUST include the regenerated live_schema.md to resolve the drift."
  echo ""
  exit 1
fi

exit 0
