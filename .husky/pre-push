#!/usr/bin/env sh
#
# Pre-push hook — MyAIM Central
#
# Orchestration Checkpoint 4: verifies state file hygiene before push.
# PRD-41 gate: the ethics red-team suite must be green before push, so a
# Tier-0 regression (a weakened pattern, a dropped category, broken reframe
# copy) cannot ship silently. See PRD-41 §Red-Team Suite Specification
# "Enforcement point" + Founder Decision Record item 8.
#
# Checks:
# - No uncommitted changes to orchestration state files
# - npm run redteam passes (tests/redteam/ — deterministic, no-network vitest
#   suite; the Playwright pins in tests/e2e/features/ethics-enforcement.spec.ts
#   are deploy-dependent and run separately as part of the Edge Function
#   deploy checklist, not here — a pre-push hook can't assume a deployed
#   validate-ai-output function or a live model exists)
#
# Override: git push --no-verify
#
# Why this matters: State files track build progress, decisions, and context.
# Pushing code without committing state updates means the next session starts
# with stale context — it won't know what was built, what's left, or what
# was decided.
#
# Part of the orchestration layer.
# See claude/orchestration/Verifier-Checkpoint-Schedule.md (Checkpoint 4).

set -e

DIRTY=""
for f in BUILD_STATUS.md STUB_REGISTRY.md WIRING_STATUS.md .claude/state/CURRENT.md .claude/state/HISTORY.md; do
  if [ -f "$f" ] && [ -n "$(git status --porcelain -- "$f" 2>/dev/null)" ]; then
    DIRTY="$DIRTY $f"
  fi
done

if [ -n "$DIRTY" ]; then
  echo ""
  echo "⚠️  PRE-PUSH CHECK — Uncommitted state file changes"
  echo ""
  echo "  Modified:$DIRTY"
  echo ""
  echo "  Why this matters: State files track build progress and decisions."
  echo "  Pushing without committing them means the next session starts"
  echo "  with stale context — it won't know what was built or decided."
  echo ""
  echo "  Fix: git add <files> && git commit -m 'chore: update state files'"
  echo "  Then retry the push."
  echo ""
  echo "  Override: git push --no-verify"
  echo ""
  exit 1
fi

if [ -f "tests/redteam/ethics-guard.test.ts" ]; then
  echo ""
  echo "🔒 PRE-PUSH CHECK — PRD-41 ethics red-team suite"
  echo ""
  if ! npm run redteam; then
    echo ""
    echo "⚠️  Red-team suite failed. This blocks push because it is the"
    echo "  regression pin for the five auto-reject categories (force,"
    echo "  coercion, manipulation, shame_based_control, withholding_affection)"
    echo "  — a silent regression here is a safety gate failure, not a"
    echo "  cosmetic test failure."
    echo ""
    echo "  Override: git push --no-verify"
    echo ""
    exit 1
  fi
fi

exit 0
